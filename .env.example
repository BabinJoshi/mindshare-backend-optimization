# Copy to .env and fill in. Connection strings (Postgres wire protocol).

# PostgreSQL: read from mindshare, write only to mindshare_score_test.
MINDSHARE_PG_URI=postgresql://user:pass@host:5432/mindshare?sslmode=require

# CockroachDB remains available for comparison runs.
MINDSHARE_DB_URI=postgresql://user:pass@host:26257/db?sslmode=require

# Schema overrides (defaults shown).
# MINDSHARE_PG_SOURCE_SCHEMA=mindshare
# MINDSHARE_PG_SCORE_SCHEMA=mindshare_score_test
# MINDSHARE_CRDB_SOURCE_SCHEMA=mindshare_test
# MINDSHARE_CRDB_SCORE_SCHEMA=mindshare_score_test

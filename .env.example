# Copy to .env and fill in. Connection strings (Postgres wire protocol).

# Postgres — the live system that ALREADY has the computed contribution_scores (golden output).
# Used by default for parity validation (source + golden read from here).
MINDSHARE_PG_URI=postgresql://user:pass@host:5432/mindshare?sslmode=require
# POSTGRES_DATABASE_URL=...   # also accepted as a fallback for the pg target

# CockroachDB — currently holds only the replicated base/source tables.
MINDSHARE_DB_URI=postgresql://user:pass@host:26257/db?sslmode=require

# Schema overrides (defaults shown). pg = live schemas, crdb = replicated test schemas.
# MINDSHARE_PG_SOURCE_SCHEMA=mindshare
# MINDSHARE_PG_SCORE_SCHEMA=mindshare_score
# MINDSHARE_CRDB_SOURCE_SCHEMA=mindshare_test
# MINDSHARE_CRDB_SCORE_SCHEMA=mindshare_score_test
